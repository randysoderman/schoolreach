# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection (Drizzle). Use the Supabase pooler URL with `?sslmode=require`.
DATABASE_URL=

# Anthropic — used for the directory-finding step (Sonnet) and as
# fallback for extraction (Haiku) when LLM_EXTRACT_PROVIDER=anthropic.
ANTHROPIC_API_KEY=

# Google Gemini — default provider for the per-page extraction step.
# Free tier covers a lot. Get a key at https://aistudio.google.com/apikey.
GEMINI_API_KEY=

# Optional: explicit provider override for extractPeople. Defaults to 'gemini'
# if GEMINI_API_KEY is set, otherwise 'anthropic'.
LLM_EXTRACT_PROVIDER=

# Scraping + search
FIRECRAWL_API_KEY=
BRAVE_SEARCH_API_KEY=

# Email (Resend)
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# CAN-SPAM compliance
COMPANY_POSTAL_ADDRESS=

# Unsubscribe link signing
UNSUBSCRIBE_SECRET=
